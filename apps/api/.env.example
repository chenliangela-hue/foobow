# NestJS API Environment
PORT=8787
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"
FOOBOW_DEV_BEARER_TOKEN="dev-foobow-token"

# Auth (Clerk)
AUTH_PROVIDER="clerk"
AUTH_ISSUER_URL="https://replace-with-your-clerk-issuer"
AUTH_AUDIENCE="foobow-api"
CLERK_SECRET_KEY="sk_test_..."

# Payments (Stripe, optional until donation test mode starts)
# STRIPE_SECRET_KEY="sk_test_..."
