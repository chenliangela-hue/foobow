{
  "name": "@foobow/api",
  "version": "0.1.0",
  "private": true,
  "description": "Foobow API runtime scaffold and typed NestJS backend target.",
  "type": "module",
  "scripts": {
    "start": "node src/server.mjs",
    "start:nest": "tsx src/nest/main.ts",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:smoke": "tsx scripts/prisma-write-smoke.ts",
    "nest:db-smoke": "tsx scripts/nest-db-http-smoke.ts",
    "test:db-integration": "tsx scripts/db-integration-suite.ts",
    "auth:clerk-smoke": "tsx scripts/clerk-auth-smoke.ts",
    "db:supabase-provision": "tsx scripts/supabase-provision.ts",
    "db:supabase-storage": "tsx scripts/supabase-storage-provision.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test tests && npm run typecheck"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "overrides": {
    "find-my-way": "^9.7.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "jose": "^6.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
