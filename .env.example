# Foobow root environment template.
# Copy to `.env.local` for local work. Do not commit real secrets.

# -----------------------------------------------------------------------------
# App identity and URLs
# -----------------------------------------------------------------------------
APP_ENV="local"
APP_NAME="Foobow"
APP_PUBLIC_URL="http://localhost:4173"
API_PUBLIC_URL="http://127.0.0.1:8787"
MOBILE_DEEP_LINK_SCHEME="foobow"

# -----------------------------------------------------------------------------
# Local/dev API auth
# -----------------------------------------------------------------------------
FOOBOW_DEV_BEARER_TOKEN="replace-with-local-dev-token"

# -----------------------------------------------------------------------------
# Clerk auth
# Required resource setup:
# - Clerk application: Foobow
# - Environments: development, production
# - Sign-in methods: email code/link, Google, Apple
# - JWT template/audience for Foobow API
# - Webhook endpoint for user sync when backend persistence is implemented
# -----------------------------------------------------------------------------
AUTH_PROVIDER="clerk"
AUTH_AUDIENCE="foobow-api"
AUTH_ISSUER_URL="https://replace-with-your-clerk-issuer"
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_JWT_KEY=""
CLERK_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Supabase managed PostgreSQL and storage
# Required resource setup:
# - Supabase project: foobow-dev / foobow-prod
# - Region selected near primary users
# - Storage buckets: avatars, journal-attachments, campaign-assets
# - DATABASE_URL should use pooled/transaction URL for app runtime
# - DIRECT_URL should use direct DB URL for migrations
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://foobow:foobow@localhost:55432/foobow?schema=public"
DIRECT_URL=""
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_PROJECT_REF=""
SUPABASE_ACCESS_TOKEN=""
SUPABASE_DB_PASSWORD=""
SUPABASE_REGION=""

# -----------------------------------------------------------------------------
# Deployment and hosting
# Recommended split:
# - Vercel: static prototype/web preview, docs preview, future marketing web
# - Container host for Nest API if persistent runtime is needed
# -----------------------------------------------------------------------------
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""
VERCEL_PROJECT_NAME="foobow"
VERCEL_TEAM_SLUG=""
API_HOSTING_PROVIDER="container"
API_CONTAINER_APP_NAME="foobow-api"

# -----------------------------------------------------------------------------
# Expo / EAS mobile build and store submission
# Required resource setup:
# - Expo project
# - Apple Developer account/team
# - Google Play Console app
# -----------------------------------------------------------------------------
EXPO_TOKEN=""
EAS_PROJECT_ID=""
EXPO_PUBLIC_API_BASE_URL="http://127.0.0.1:8787"
IOS_BUNDLE_IDENTIFIER="com.foobow.app"
ANDROID_PACKAGE="com.foobow.app"
APPLE_TEAM_ID=""
ASC_APP_ID=""
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_BASE64=""

# -----------------------------------------------------------------------------
# Stripe payments, donations, and subscriptions
# Required resource setup:
# - Stripe account
# - Products/prices for optional subscription tiers
# - Donation checkout/payment flow
# - Webhook endpoint for payment confirmation
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_DONATION_PRICE_ID=""
STRIPE_SUBSCRIPTION_PRICE_ID_AD_FREE=""
STRIPE_SUBSCRIPTION_PRICE_ID_FAMILY=""

# -----------------------------------------------------------------------------
# Mapbox maps
# Required resource setup:
# - Public mobile token restricted to app identifiers where possible
# - Optional custom style for calm Foobow map theme
# -----------------------------------------------------------------------------
EXPO_PUBLIC_MAPBOX_TOKEN=""
MAPBOX_STYLE_URL=""
MAPBOX_DOWNLOAD_TOKEN=""

# -----------------------------------------------------------------------------
# Observability: Sentry
# Required resource setup:
# - Sentry org
# - Projects: foobow-api, foobow-mobile
# - CI auth token for source maps/releases
# -----------------------------------------------------------------------------
SENTRY_DSN=""
EXPO_PUBLIC_SENTRY_DSN_MOBILE=""
SENTRY_ORG=""
SENTRY_PROJECT_API="foobow-api"
SENTRY_PROJECT_MOBILE="foobow-mobile"
SENTRY_AUTH_TOKEN=""

# -----------------------------------------------------------------------------
# Product analytics: PostHog
# Required resource setup:
# - PostHog project
# - Decide US/EU host based on privacy/data residency
# -----------------------------------------------------------------------------
POSTHOG_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"
EXPO_PUBLIC_POSTHOG_KEY=""
EXPO_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# -----------------------------------------------------------------------------
# Transactional email: Resend
# Required resource setup:
# - Verified sending domain
# - DNS records for SPF/DKIM/DMARC
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM="Foobow <noreply@foobow.com>"
SUPPORT_EMAIL="support@foobow.com"

# -----------------------------------------------------------------------------
# Moderation and AI safety
# Optional until user-generated content volume grows.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=""
MODERATION_PROVIDER="manual"
ADMIN_EMAILS=""

# -----------------------------------------------------------------------------
# Feature flags and policy controls
# -----------------------------------------------------------------------------
FEATURE_DONATIONS_ENABLED="false"
FEATURE_SUBSCRIPTIONS_ENABLED="false"
FEATURE_ADS_ENABLED="false"
FEATURE_REAL_MAP_PROVIDER_ENABLED="false"
DONATION_TRANSPARENCY_COPY="Donation support is separate from symbolic karma and does not buy luck, virtue, or guaranteed outcomes."
