# =============================================================================
# FOOBOW MVP ENVIRONMENT SETUP
# =============================================================================
# Copy this file to `.env` (root) for local development.
# IMPORTANT: Keys starting with EXPO_PUBLIC_ are visible in the mobile app.

# -----------------------------------------------------------------------------
# 1. CORE API & DATABASE (Supabase)
# -----------------------------------------------------------------------------
# For local Docker Postgres, this value works with `docker compose up -d foobow-postgres`.
# For Supabase, replace it with Project Settings > Database > Connection string.
DATABASE_URL="postgresql://foobow:foobow@localhost:55432/foobow?schema=public"

# Local API guard token. This is your own random dev string, not a provider key.
FOOBOW_DEV_BEARER_TOKEN="dev-foobow-token"

# Server auth settings. Keep the secret server-side; never expose it through EXPO_PUBLIC_.
AUTH_PROVIDER="clerk"
AUTH_ISSUER_URL="https://replace-with-your-clerk-issuer"
AUTH_AUDIENCE="foobow-api"

# Mobile app API URL. This is public because the app must know where to call.
EXPO_PUBLIC_API_URL="http://localhost:8787"

# -----------------------------------------------------------------------------
# 2. AUTHENTICATION (Clerk)
# -----------------------------------------------------------------------------
# 1. Create a project at clerk.com
# 2. Get these from "API Keys" in the Clerk dashboard.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# -----------------------------------------------------------------------------
# 3. MAPS (OpenStreetMap / MapLibre default)
# -----------------------------------------------------------------------------
# No key is required for the default MVP map path.
# Use OpenStreetMap-derived tiles with visible attribution and provider policy compliance.
EXPO_PUBLIC_MAP_PROVIDER="osm"
EXPO_PUBLIC_MAP_TILE_URL="https://tile.openstreetmap.org/{z}/{x}/{y}.png"
EXPO_PUBLIC_MAP_ATTRIBUTION="OpenStreetMap contributors"

# Optional premium map provider. Add only if you later choose Mapbox or another paid tile host.
# EXPO_PUBLIC_MAPBOX_TOKEN="pk.eyJ1..."

# -----------------------------------------------------------------------------
# 4. PAYMENTS (Stripe)
# -----------------------------------------------------------------------------
# Optional for the first MVP. Add these only when donation/subscription test mode starts.
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."

# =============================================================================
# DEFERRED (NOT NEEDED FOR INITIAL MVP RUN)
# =============================================================================
# STRIPE_WEBHOOK_SECRET=""         # Only needed for backend payment sync
# SENTRY_DSN=""                    # API error tracking
# EXPO_PUBLIC_SENTRY_DSN_MOBILE="" # Mobile error tracking DSN, safe to expose
# POSTHOG_KEY=""                   # Server analytics key
# EXPO_PUBLIC_POSTHOG_KEY=""       # Mobile analytics project key, safe to expose
# EXPO_TOKEN=""                    # Only needed for cloud builds (EAS)
# VERCEL_TOKEN=""                  # Only needed for deployment automation

# No email API key is required for the initial MVP.
# Clerk can handle account emails and Stripe can handle payment receipts when enabled.
