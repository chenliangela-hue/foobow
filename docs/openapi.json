{
  "openapi": "3.1.0",
  "info": {
    "title": "Foobow API",
    "version": "0.1.0",
    "description": "Product-level API contract for the Foobow virtual good karma MVP."
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "paths": {
    "/me": {
      "get": {
        "summary": "Get the current user profile and settings",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MeResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/me/profile": {
      "patch": {
        "summary": "Update profile preferences",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProfileUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated profile" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/today": {
      "get": {
        "summary": "Get today's ritual state",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Today state" }
        }
      }
    },
    "/checkins": {
      "post": {
        "summary": "Create today's mood check-in",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CheckinCreateRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Check-in created" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/map-spots": {
      "get": {
        "summary": "List map spots",
        "parameters": [
          { "$ref": "#/components/parameters/Cursor" },
          { "$ref": "#/components/parameters/Category" },
          { "$ref": "#/components/parameters/Region" }
        ],
        "responses": {
          "200": {
            "description": "Paginated map spots",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MapSpotPage" }
              }
            }
          }
        }
      }
    },
    "/deed-types": {
      "get": {
        "summary": "List active deed types",
        "parameters": [
          { "$ref": "#/components/parameters/Cursor" },
          { "$ref": "#/components/parameters/Category" }
        ],
        "responses": {
          "200": {
            "description": "Paginated deed types",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeedTypePage" }
              }
            }
          }
        }
      }
    },
    "/deed-actions": {
      "post": {
        "summary": "Complete a symbolic deed action",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeedActionCreateRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Deed action completed" }
        }
      }
    },
    "/blessings": {
      "get": {
        "summary": "List moderated blessing wall posts",
        "parameters": [{ "$ref": "#/components/parameters/Cursor" }],
        "responses": {
          "200": { "description": "Paginated visible blessings" }
        }
      },
      "post": {
        "summary": "Create a blessing",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BlessingCreateRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Blessing created" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/reports": {
      "post": {
        "summary": "Report unsafe content or behavior",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ReportCreateRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Report created" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/donation-campaigns": {
      "get": {
        "summary": "List verified donation campaigns",
        "parameters": [{ "$ref": "#/components/parameters/Cursor" }],
        "responses": {
          "200": { "description": "Paginated verified campaigns" }
        }
      }
    },
    "/donations": {
      "post": {
        "summary": "Create a donation checkout for a verified campaign",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdempotencyKey" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DonationCreateRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Donation checkout created" },
          "409": { "$ref": "#/components/responses/IdempotencyConflict" },
          "422": { "$ref": "#/components/responses/UnverifiedCampaign" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "parameters": {
      "Cursor": {
        "name": "cursor",
        "in": "query",
        "schema": { "type": "string" }
      },
      "Category": {
        "name": "category",
        "in": "query",
        "schema": { "$ref": "#/components/schemas/Category" }
      },
      "Region": {
        "name": "region",
        "in": "query",
        "schema": { "type": "string" }
      },
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 16,
          "maxLength": 128
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid session"
      },
      "ValidationError": {
        "description": "Request validation failed",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Conflict": {
        "description": "Resource conflict"
      },
      "RateLimited": {
        "description": "Rate limit exceeded"
      },
      "IdempotencyConflict": {
        "description": "Idempotency key was reused with a different payload"
      },
      "UnverifiedCampaign": {
        "description": "Donation campaign is not verified or active"
      }
    },
    "schemas": {
      "Category": {
        "type": "string",
        "enum": ["animals", "elders", "environment", "support", "donation", "remembrance"]
      },
      "PageInfo": {
        "type": "object",
        "required": ["has_next_page"],
        "properties": {
          "next_cursor": { "type": ["string", "null"] },
          "has_next_page": { "type": "boolean" }
        }
      },
      "MeResponse": {
        "type": "object",
        "required": ["user", "profile"],
        "properties": {
          "user": { "type": "object" },
          "profile": { "type": "object" }
        }
      },
      "ProfileUpdateRequest": {
        "type": "object",
        "properties": {
          "display_name": { "type": "string", "minLength": 1 },
          "locale": { "type": "string" },
          "privacy_mode": { "type": "string", "enum": ["public", "friends_only", "anonymous", "private"] },
          "quiet_ranking_enabled": { "type": "boolean" }
        }
      },
      "CheckinCreateRequest": {
        "type": "object",
        "required": ["mood"],
        "properties": {
          "mood": { "type": "string", "enum": ["calm", "heavy", "lonely", "grateful", "hopeful", "anxious"] },
          "note": { "type": "string", "maxLength": 500 }
        }
      },
      "DeedActionCreateRequest": {
        "type": "object",
        "required": ["deed_type_id", "status"],
        "properties": {
          "deed_type_id": { "type": "string" },
          "map_spot_id": { "type": "string" },
          "status": { "type": "string", "enum": ["started", "completed"] },
          "visibility": { "type": "string", "enum": ["public", "friends_only", "anonymous", "private"] }
        }
      },
      "BlessingCreateRequest": {
        "type": "object",
        "required": ["body", "visibility"],
        "properties": {
          "body": { "type": "string", "minLength": 1, "maxLength": 140 },
          "visibility": { "type": "string", "enum": ["anonymous", "public", "private"] }
        }
      },
      "ReportCreateRequest": {
        "type": "object",
        "required": ["target_type", "target_id", "reason"],
        "properties": {
          "target_type": { "type": "string", "enum": ["profile", "blessing", "campaign", "deed_action", "group_mission"] },
          "target_id": { "type": "string" },
          "reason": { "type": "string", "minLength": 1, "maxLength": 300 }
        }
      },
      "DonationCreateRequest": {
        "type": "object",
        "required": ["campaign_id", "amount", "currency"],
        "properties": {
          "campaign_id": { "type": "string" },
          "amount": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]{2})$" },
          "currency": { "type": "string", "enum": ["USD", "CAD"] }
        }
      },
      "MapSpotPage": {
        "type": "object",
        "required": ["items", "page_info"],
        "properties": {
          "items": { "type": "array", "items": { "type": "object" } },
          "page_info": { "$ref": "#/components/schemas/PageInfo" }
        }
      },
      "DeedTypePage": {
        "type": "object",
        "required": ["items", "page_info"],
        "properties": {
          "items": { "type": "array", "items": { "type": "object" } },
          "page_info": { "$ref": "#/components/schemas/PageInfo" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message", "request_id"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "details": { "type": "array", "items": { "type": "object" } },
              "request_id": { "type": "string" }
            }
          }
        }
      }
    }
  }
}

