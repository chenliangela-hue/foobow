{
  "name": "foobow",
  "version": "0.1.0",
  "private": true,
  "description": "Foobow virtual good karma app product docs and clickable prototype.",
  "type": "module",
  "scripts": {
    "test": "node --test tests",
    "test:unit": "node --test tests/unit-content.test.mjs",
    "test:smoke": "node --test tests/smoke-prototype.test.mjs",
    "test:pa": "node --test tests/pa-checklist.test.mjs",
    "test:api": "npm --prefix apps/api test",
    "test:browser": "playwright test tests/browser/foobow.pa.spec.mjs",
    "test:visual": "playwright test tests/browser/foobow.visual.spec.mjs",
    "test:mobile": "npm --prefix apps/mobile run typecheck",
    "test:catalog": "node scripts/verify-shared-catalog.mjs",
    "test:env": "node scripts/verify-env-contract.mjs",
    "test:advisories": "node scripts/verify-advisory-watchlist.mjs",
    "audit:high": "npm audit --audit-level=high",
    "audit:api:high": "npm --prefix apps/api audit --audit-level=high",
    "audit:mobile:high": "npm --prefix apps/mobile audit --audit-level=high",
    "test:security": "npm run audit:high && npm run audit:api:high && npm run audit:mobile:high",
    "test:all": "npm test && npm run test:catalog && npm run test:env && npm run test:advisories && npm run test:api && npm run test:mobile && npm run test:browser && npm run test:visual && npm run test:security",
    "serve": "python -m http.server 4173 --bind 127.0.0.1 --directory prototype"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
